def partition(arr, low, high):
    pivot = arr[high]
    i = low - 1
    j = low
    while j <= high - 1:
        if arr[j] <= pivot:
            i = i + 1
            temp = arr[i]
            arr[i] = arr[j]
            arr[j] = temp
        j = j + 1
    temp = arr[i + 1]
    arr[i + 1] = arr[high]
    arr[high] = temp
    return i + 1

def quicksort_aux(arr, low, high):
    if low < high:
        pivot_index = partition(arr, low, high)
        quicksort_aux(arr, low, pivot_index - 1)
        quicksort_aux(arr, pivot_index + 1, high)

def quicksort(array):
    quicksort_aux(array, 0, len(array) - 1)

